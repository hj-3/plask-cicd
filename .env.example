# Database
DATABASE_URL=postgresql://user:password@localhost:5432/plask

# Redis 1: Session & Cache
SESSION_REDIS_HOST=localhost
SESSION_REDIS_PORT=6379

# Redis 2: FIFO Order Queue
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6380
QUEUE_NAME=order-queue

# Backend
PORT=3002
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRES_IN=24h

# Admin account (auto-created on startup)
ADMIN_EMAIL=admin@plask.com
ADMIN_PASSWORD=admin1234
ADMIN_NAME=관리자

# SMTP Email (configure with your SMTP provider)
# Gmail: enable 2FA and create App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@plask.com

# Frontend
API_BASE_URL=
VITE_API_BASE_URL=
